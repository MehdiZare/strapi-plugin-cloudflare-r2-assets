# Required — integration tests are skipped unless all four are set
CF_R2_ACCESS_KEY_ID=
CF_R2_ACCOUNT_ID=
CF_R2_BUCKET=
CF_R2_SECRET_ACCESS_KEY=

# Optional — defaults to https://placeholder.example.com in tests
CF_PUBLIC_BASE_URL=

# Optional — request timeout in milliseconds (default: 30000)
CF_R2_REQUEST_TIMEOUT=
